# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env
.env.*
.env*.local

# typescript
*.tsbuildinfo

app-example

# generated native folders
/ios
/android

# Build artifacts (regenerated on deploy)
dist/
server_dist/
static-build/

# Replit-specific
.replit
.config/
.local/
.upm/
.cache/
cookies.txt

# Expo cache
.expo/

# User-generated content (recreated at runtime)
attached_assets/
public/downloads/

# Root-level screenshots and test files
/*.png
/*.pdf

# Python (Replit import scripts, not part of Node app)
pyproject.toml
uv.lock
main.py
__pycache__/
*.pyc

# Windows
Thumbs.db

# Database backups (contain sensitive data — never commit)
backup.sql
backup-inserts.sql
